# Copy to .env and edit for your environment. The .env file is gitignored.

# Postgres connection string for running the API directly on the host.
# Docker Compose hardcodes the app container to use db:5432 internally.
DATABASE_URL=postgres://thedaolog:thedaolog@localhost:15432/thedaolog

# Optional host port override for direct access to the API container.
APP_PORT=7101

# Caddy reverse proxy (public entrypoint). SITE_ADDRESS sets the Caddy
# site block: ":80" for plain local HTTP, "localhost" for a local TLS
# cert, or a real domain (e.g. thedaolog.giveth.io) for automatic
# Let's Encrypt certificates.
SITE_ADDRESS=:80

# Optional integrations used by server/api.mjs. Leave blank to disable.
PINATA_JWT=
GITHUB_TOKEN=
THEDAOLOG_GITHUB_REPO=

# Required only for on-chain root commits and deploy/mint scripts. Prefer
# DEPLOYER_PRIVATE_KEY for containerized runs; DEPLOYER_KEY_FILE can point
# to a local JSON file with { "privateKey": "...", "address": "..." }.
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=
DEPLOYER_KEY_FILE=
CONTRACTS_LOG_FILE=data/thedaolog_contracts.json

# Optional: WalletConnect projectId. Without this the WalletConnect QR
# flow won't work, but injected wallets (Rabby, MetaMask, Frame) still do.
# VITE_WALLETCONNECT_PROJECT_ID=
