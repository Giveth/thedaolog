# Copy to .env and edit for your environment. The .env file is gitignored.

# Postgres connection string. The default works against the local
# docker-compose.yml setup. For Kay's deploy, point at the org's
# managed Postgres.
DATABASE_URL=postgres://thedaolog:thedaolog@localhost:15432/thedaolog

# Optional: WalletConnect projectId. Without this the WalletConnect QR
# flow won't work, but injected wallets (Rabby, MetaMask, Frame) still do.
# Get one at https://cloud.reown.com
# VITE_WALLETCONNECT_PROJECT_ID=
